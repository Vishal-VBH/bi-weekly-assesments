<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	id="WebApp_ID" version="4.0">

	<display-name>insurance-assessment</display-name>

	<welcome-file-list>
		<welcome-file>login.jsp</welcome-file>
	</welcome-file-list>


	<servlet>
		<servlet-name>LoginServlet</servlet-name>
		<servlet-class>com.training.servlet.LoginServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>CustomerRegisterServlet</servlet-name>
		<servlet-class>com.training.servlet.CustomerRegistrationServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>AdminServlet</servlet-name>
		<servlet-class>com.training.servlet.AdminServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>PolicyListServlet</servlet-name>
		<servlet-class>com.training.servlet.PolicyListServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>PurchaseServlet</servlet-name>
		<servlet-class>com.training.servlet.PurchaseServlet</servlet-class>
	</servlet>


	<servlet-mapping>
		<servlet-name>LoginServlet</servlet-name>
		<url-pattern>/login</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>CustomerRegisterServlet</servlet-name>
		<url-pattern>/register</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>AdminServlet</servlet-name>
		<url-pattern>/admin</url-pattern>
	</servlet-mapping>

	<servlet>
		<servlet-name>LogoutServlet</servlet-name>
		<servlet-class>com.training.servlet.LogoutServlet</servlet-class>
	</servlet>

	<servlet-mapping>
		<servlet-name>LogoutServlet</servlet-name>
		<url-pattern>/logout</url-pattern>
	</servlet-mapping>

	<servlet-mapping>
		<servlet-name>PolicyListServlet</servlet-name>
		<url-pattern>/policies</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>PurchaseServlet</servlet-name>
		<url-pattern>/purchase</url-pattern>
	</servlet-mapping>

	<servlet>
		<servlet-name>MyPurchasesServlet</servlet-name>
		<servlet-class>com.training.servlet.MyPurchasesServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>MyPurchasesServlet</servlet-name>
		<url-pattern>/purchases</url-pattern>
	</servlet-mapping>


</web-app>
